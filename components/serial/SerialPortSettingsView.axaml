<UserControl
  x:Class="components.SerialPortSettingsView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="https://github.com/avaloniaui/designer"
  xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="clr-namespace:components"
  x:DataType="vm:SerialPortSettingsViewModel"
  mc:Ignorable="d">
  <UserControl.DataContext>
    <vm:SerialPortSettingsViewModel />
  </UserControl.DataContext>
  <Border Margin="10" Padding="10">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="2*" />
        <RowDefinition Height="3*" />
      </Grid.RowDefinitions>
      <!--  数据区纵向排列  -->
      <StackPanel
        Grid.Row="0"
        Margin="0,0,0,10"
        HorizontalAlignment="Stretch"
        Spacing="8">
        <TextBox
          Name="ReceiveTextBox"
          Height="80"
          HorizontalAlignment="Stretch"
          AcceptsReturn="True"
          IsReadOnly="True"
          Text="{Binding ReceiveText, UpdateSourceTrigger=PropertyChanged}" />
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
          <TextBlock
            FontSize="14"
            FontWeight="Bold"
            Text="接收区" />
          <!-- <Button Content="" Command="{Binding SerialReceiveCommand}" /> -->
        </StackPanel>
        <TextBox
          Name="SendTextBox"
          Height="80"
          HorizontalAlignment="Stretch"
          AcceptsReturn="True"
          Text="{Binding SendText, UpdateSourceTrigger=PropertyChanged}" />
          
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
          <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="Bold"
            Text="发送区" />
            <Button Name = "sendbutton" Content="发送" Command="{Binding SerialSendCommand}" />
        </StackPanel>
      </StackPanel>
      <!--  设置表单加滚动  -->
      <ScrollViewer
        Grid.Row="1"
        Grid.RowSpan="2"
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollBarVisibility="Auto">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <TextBlock
              HorizontalAlignment="Left"
              FontSize="16"
              FontWeight="Bold"
              Text="串口设置" />
          </Grid>
          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Top">
              <TextBlock
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="16"
                Text="串口号:" />
            </Grid>
            <Grid Grid.Column="1" VerticalAlignment="Top">
              <ComboBox
                Name="PortComboBox"
                MinWidth="120"
                MinHeight="32"
                Padding="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                DropDownOpened="PortComboBox_DropDownOpened"
                FontSize="16"
                ItemsSource="{Binding PortNames}"
                SelectedItem="{Binding SelectedPort}" />
            </Grid>
          </Grid>
          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Top">
              <TextBlock
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="16"
                Text="波特率:" />
            </Grid>
            <Grid Grid.Column="1" VerticalAlignment="Top">
              <ComboBox
                MinWidth="120"
                MinHeight="32"
                Padding="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FontSize="16"
                ItemsSource="{Binding BaudRates}"
                SelectedItem="{Binding SelectedBaudRate}" />
            </Grid>
          </Grid>
          <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Top">
              <TextBlock
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="16"
                Text="校验位:" />
            </Grid>
            <Grid Grid.Column="1" VerticalAlignment="Top">
              <ComboBox
                MinWidth="120"
                MinHeight="32"
                Padding="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FontSize="16"
                ItemsSource="{Binding ParityOptions}"
                SelectedItem="{Binding SelectedParity}" />
            </Grid>
          </Grid>
          <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Top">
              <TextBlock
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="16"
                Text="数据位:" />
            </Grid>
            <Grid Grid.Column="1" VerticalAlignment="Top">
              <ComboBox
                MinWidth="120"
                MinHeight="32"
                Padding="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FontSize="16"
                ItemsSource="{Binding DataBitsOptions}"
                SelectedItem="{Binding SelectedDataBits}" />
            </Grid>
          </Grid>
          <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Top">
              <TextBlock
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="16"
                Text="停止位:" />
            </Grid>
            <Grid Grid.Column="1" VerticalAlignment="Top">
              <ComboBox
                MinWidth="120"
                MinHeight="32"
                Padding="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FontSize="16"
                ItemsSource="{Binding StopBitsOptions}"
                SelectedItem="{Binding SelectedStopBits}" />
            </Grid>
          </Grid>
          <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" VerticalAlignment="Top">
              <TextBlock
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="16"
                Text="握手方式:" />
            </Grid>
            <Grid Grid.Column="1" VerticalAlignment="Top">
              <ComboBox
                MinWidth="120"
                MinHeight="32"
                Padding="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FontSize="16"
                ItemsSource="{Binding HandshakeOptions}"
                SelectedItem="{Binding SelectedHandshake}" />
            </Grid>
          </Grid>
          <Grid Grid.Row="7">
            <Button
              Width="100"
              Margin="0,12,0,0"
              HorizontalAlignment="Left"
              Command="{Binding ConfirmCommand}"
              Content="连接" />

          </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
