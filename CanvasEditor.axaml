<UserControl
    x:Class="paramlab_cs.CanvasEditor"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Source="avares://paramlab_cs/assets/editor-bg.png"
            Stretch="UniformToFill" />
        <Canvas x:Name="EditorCanvas" Background="#84FFFFFF" />
    </Grid>
</UserControl>